---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'David Parraga M. - Desarrollador Full Stack | IA Aplicada',
	description = 'Portafolio de David Parraga M. enfocado en desarrollo full stack y soluciones con IA aplicada.',
} = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
			rel="stylesheet"
		/>
		<script is:inline>
			const storedTheme = localStorage.getItem('theme');
			if (storedTheme === 'light') {
				document.documentElement.classList.remove('dark');
			} else {
				document.documentElement.classList.add('dark');
			}
		</script>
	</head>
	<body
		class="bg-background-light font-sans text-slate-900 antialiased transition-colors duration-300 selection:bg-primary selection:text-white dark:bg-background-dark dark:text-slate-200"
	>
		<slot />
	</body>
</html>
